FLASK_ENV=production
FLASK_DEBUG=0

# Admin dashboard authentication (required for secure admin routes)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_FULL_NAME=Nom Prénom
ADMIN_GYM_NAME=Ma Salle de Sport
ADMIN_PHONE=770000000
ADMIN_ADDRESS=Adresse complète

# Superadmin plateforme (optionnel)
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=
SUPERADMIN_FULL_NAME=Super Administrateur
SUPERADMIN_PHONE=
SUPERADMIN_ADDRESS=

# Operator (création / impression sans dashboard). Laisser vide si vous n'utilisez que le compte admin.
# Si ADMIN_PASSWORD ou OPERATOR_PASSWORD est défini, le site exige une connexion.
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=

# Durée de session (heures)
SESSION_HOURS=12

# Dashboard : max documents Firestore chargés pour la liste (filtres puis pagination)
LIST_QR_FETCH_MAX=3000
# Cache réponse GET /api/list_qr (secondes ; 0=désactivé). Défaut applicatif 15 s si absent.
LIST_QR_RESPONSE_CACHE_SECONDS=15
# Cooldown migration QR sans owner (secondes ; 0=toujours scanner). Défaut applicatif 86400 (24 h).
ATTACH_UNOWNED_QR_COOLDOWN_SECONDS=86400
# Lignes affichées par page dans le tableau
LIST_QR_PER_PAGE=15
# Ancien nom : encore lu si LIST_QR_FETCH_MAX absent (ex. LIST_QR_MAX_ROWS=500)
DASHBOARD_REFRESH_MS=120000

# Flask session and CSRF secret
SECRET_KEY=change-me-random-long-secret

# HMAC key used to sign QR payloads
QR_SIGNATURE_KEY=change-me-random-long-signature-key

# Firestore configuration (base principale)
FIRESTORE_PROJECT_ID=your-gcp-project-id
FIRESTORE_COLLECTION_PREFIX=qrprint
# JSON service account path (local/dev)
# GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\service-account.json

# Optional printer network configuration
# PRINTER_NETWORK_IP=192.168.1.100
# PRINTER_NETWORK_PORT=9100
# Cache du statut imprimante pour /api/status (secondes ; 0 = pas de cache)
# PRINTER_STATUS_CACHE_SECONDS=25

# Port application (Ã©vite les conflits). Sur Render, PORT est imposé par la plateforme.
APP_PORT=5055

# --- Déploiement Render (https://render.com) ---
# 1) Pousser le repo sur GitHub. Web Service depuis render.yaml (build / preDeploy / start).
#    Commande de démarrage Render : gunicorn --bind 0.0.0.0:$PORT --workers 1 --threads 2 app:app
#    (pas « gunicorn app:app » seul — sinon mauvais port / crash.)
#    PYTHON_VERSION / runtime.txt / .python-version → viser 3.12.8 si Render part encore en 3.14.
# 2) Render → Environment : copier les variables depuis votre .env local (sans committer le .env).
#    Obligatoires typiques : SECRET_KEY, QR_SIGNATURE_KEY, FIRESTORE_PROJECT_ID,
#    GOOGLE_APPLICATION_CREDENTIALS_JSON (JSON compte de service GCP en une ligne),
#    GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, ADMIN_PASSWORD, etc.
# 3) Google OAuth : ajouter l’URL Render dans la console Google, ex. :
#    Origine JS : https://votre-service.onrender.com
#    Redirection : https://votre-service.onrender.com/auth/google/callback
# Render définit PORT et RENDER=true (HTTPS derrière proxy ; OAuth OK).

# Corps JSON du compte de service GCP (alternative au fichier GOOGLE_APPLICATION_CREDENTIALS). Obligatoire sur Render si pas de fichier.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Connexion Google (OAuth 2.0). Console Google Cloud → APIs et services → Identifiants → ID client OAuth.
# Dans le client Web, renseigner :
#   Origines JavaScript autorisées : http://127.0.0.1:5055  (et/ou http://localhost:5055)
#   URI de redirection autorisées : http://127.0.0.1:5055/auth/google/callback  (même hôte/port que le navigateur)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# En prod HTTPS, ne pas définir OAUTHLIB_INSECURE_TRANSPORT. En local HTTP sans FLASK_DEBUG=1 :
# OAUTHLIB_INSECURE_TRANSPORT=1

# Texte du ticket thermique (optionnel)
# TICKET_PREVIEW_WIDTH_CHARS=52
# TICKET_WIDTH_CHARS=32
# TICKET_RECEIPT_TITLE=REÇU
# TICKET_SUBTITLE=SALLE DE GYM
# TICKET_THANKS=MERCI DE VOTRE FIDÉLITÉ
# TICKET_CAISSE_LABEL=CAISSE
